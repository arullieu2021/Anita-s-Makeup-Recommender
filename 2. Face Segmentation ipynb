putId);\n","  const outputElement = document.getElementById(outputId);\n","  // Cache steps on the outputElement to make it available for the next call\n","  // to uploadFilesContinue from Python.\n","  outputElement.steps = steps;\n","\n","  return _uploadFilesContinue(outputId);\n","}\n","\n","// This is roughly an async generator (not supported in the browser yet),\n","// where there are multiple asynchronous steps and the Python side is going\n","// to poll for completion of each step.\n","// This uses a Promise to block the python side on completion of each step,\n","// then passes the result of the previous step as the input to the next step.\n","function _uploadFilesContinue(outputId) {\n","  const outputElement = document.getElementById(outputId);\n","  const steps = outputElement.steps;\n","\n","  const next = steps.next(outputElement.lastPromiseValue);\n","  return Promise.resolve(next.value.promise).then((value) => {\n","    // Cache the last promise value to make it available to the next\n","    // step of the generator.\n","    outputElement.lastPromiseValue = value;\n","    return next.value.response;\n","  });\n","}\n","\n","/**\n"," * Generator function which is called between each async step of the upload\n"," * process.\n"," * @param {string} inputId Element ID of the input file picker element.\n"," * @param {string} outputId Element ID of the output display.\n"," * @return {!Iterable<!Object>} Iterable of next steps.\n"," */\n","function* uploadFilesStep(inputId, outputId) {\n","  const inputElement = document.getElementById(inputId);\n","  inputElement.disabled = false;\n","\n","  const outputElement = document.getElementById(outputId);\n","  outputElement.innerHTML = '';\n","\n","  const pickedPromise = new Promise((resolve) => {\n","    inputElement.addEventListener('change', (e) => {\n","      resolve(e.target.files);\n","    });\n","  });\n","\n","  const cancel = document.createElement('button');\n","  inputElement.parentElement.appendChild(cancel);\n","  cancel.textContent = 'Cancel upload';\n","  const cancelPromise = new Promise((resolve) => {\n","    cancel.onclick = () => {\n","      resolve(null);\n","    };\n","  });\n","\n","  // Wait for the user to pick the files.\n","  const files = yield {\n","    promise: Promise.race([pickedPromise, cancelPromise]),\n","    response: {\n","      action: 'starting',\n","    }\n","  };\n","\n","  cancel.remove();\n","\n","  // Disable the input element since further picks are not allowed.\n","  inputElement.disabled = true;\n","\n","  if (!files) {\n","    return {\n","      response: {\n","        action: 'complete',\n","      }\n","    };\n","  }\n","\n","  for (const file of files) {\n","    const li = document.createElement('li');\n","    li.append(span(file.name, {fontWeight: 'bold'}));\n","    li.append(span(\n","        `(${file.type || 'n/a'}) - ${file.size} bytes, ` +\n","        `last modified: ${\n","            file.lastModifiedDate ? file.lastModifiedDate.toLocaleDateString() :\n","                                    'n/a'} - `));\n","    const percent = span('0% done');\n","    li.appendChild(percent);\n","\n","    outputElement.appendChild(li);\n","\n","    const fileDataPromise = new Promise((resolve) => {\n","      const reader = new FileReader();\n","      reader.onload = (e) => {\n","        resolve(e.target.result);\n","      };\n","      reader.readAsArrayBuffer(file);\n","    });\n","    // Wait for the data to be ready.\n","    let fileData = yield {\n","      promise: fileDataPromise,\n","      response: {\n","        action: 'continue',\n","      }\n","    };\n","\n","    // Use a chunked sending to avoid message size limits. See b/62115660.\n","    let position = 0;\n","    do {\n","      const length = Math.min(fileData.byteLength - position, MAX_PAYLOAD_SIZE);\n","      const chunk = new Uint8Array(fileData, position, length);\n","      position += length;\n","\n","      const base64 = btoa(String.fromCharCode.apply(null, chunk));\n","      yield {\n","        response: {\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.google.colab || {};\n","scope.google.colab._files = {\n","  _uploadFiles,\n","  _uploadFilesContinue,\n","};\n","})(self);\n","</script> "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saving anita.jpg to anita (2).jpg\n","Prompt 'skin of the face': found 1 objects\n","Prompt 'eyebrows': found 3 objects\n","Prompt 'lips': found 1 objects\n","Prompt 'nose': found 1 objects\n","\n","======================================================================\n","👁️  Left Iris — click on the eye in the photo\n","======================================================================\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","    <div style=\"font-family:monospace; max-width:700px;\">\n","      <h3 style=\"margin-bottom:4px;\">\n","        👁️ Left Iris — Pick eye color\n","      </h3>\n","      <p style=\"margin:0 0 10px 0; font-size:12px; color:#666;\">\n","        🖱️ Hover to preview &nbsp;|&nbsp;\n","        🖱️ Click to lock color &nbsp;|&nbsp;\n","        🖱️ Double-click to unlock &nbsp;|&nbsp;\n","        ✅ Press Confirm when ready\n","      </p>\n","      <div style=\"display:flex; gap:24px; align-items:flex-start;\">\n","\n","        <div style=\"position:relative; width:480px; height:640px;\n","                    cursor:crosshair; flex-shrink:0;\">\n","          <img id=\"photo_left_iris\"\n","               src=\"data:image/jpeg;base64,\"\n","               width=\"480\" height=\"640\"\n","               style=\"display:block; position:absolute; top:0; left:0;\n","                      user-select:none; -webkit-user-drag:none;\"/>\n","          <canvas id=\"canvas_left_iris\"\n","                  width=\"480\" height=\"640\"\n","                  style=\"position:absolute; top:0; left:0;\"></canvas>\n","        </div>\n","\n","        <div style=\"display:flex; flex-direction:column; gap:12px; min-width:170px;\">\n","          <div id=\"swatch_left_iris\"\n","               style=\"width:130px; height:130px; border-radius:12px;\n","                      border:2px solid #ccc; background:#6496C8;\n","                      transition: background 0.1s;\"></div>\n","          <div id=\"hex_label_left_iris\"\n","               style=\"font-size:22px; font-weight:bold; letter-spacing:1px;\">\n","            #6496C8\n","          </div>\n","          <div id=\"rgb_label_left_iris\" style=\"font-size:13px; color:#555;\">\n","            RGB: hover over image\n","          </div>\n","          <div id=\"status_left_iris\"\n","               style=\"font-size:12px; color:#888; min-height:18px;\">\n","            Click image to lock a color\n","          </div>\n","          <button onclick=\"confirmColor_left_iris()\"\n","                  style=\"margin-top:4px; padding:10px 18px; font-size:14px;\n","                         background:#2196F3; color:white; border:none;\n","                         border-radius:8px; cursor:pointer; font-weight:bold;\">\n","            ✅ Confirm this color\n","          </button>\n","        </div>\n","      </div>\n","    </div>\n","\n","    <script>\n","    (function() {\n","      const canvas  = document.getElementById('canvas_left_iris');\n","      const ctx     = canvas.getContext('2d');\n","      const imgEl   = document.getElementById('photo_left_iris');\n","      const swatch  = document.getElementById('swatch_left_iris');\n","      const hexLbl  = document.getElementById('hex_label_left_iris');\n","      const rgbLbl  = document.getElementById('rgb_label_left_iris');\n","      const status  = document.getElementById('status_left_iris');\n","\n","      const off = document.createElement('canvas');\n","      off.width = 480; off.height = 640;\n","      const offCtx = off.getContext('2d');\n","      const drawOff = () => offCtx.drawImage(imgEl, 0, 0);\n","      if (imgEl.complete) drawOff(); else imgEl.onload = drawOff;\n","\n","      let locked = false;\n","\n","      function toHex(r, g, b) {\n","        return '#' + [r,g,b].map(v =>\n","          v.toString(16).padStart(2,'0').toUpperCase()).join('');\n","      }\n","\n","      function getAvgColor(x, y, radius=8) {\n","        const x1 = Math.max(0, x-radius), y1 = Math.max(0, y-radius);\n","        const x2 = Math.min(480, x+radius), y2 = Math.min(640, y+radius);\n","        const data = offCtx.getImageData(x1, y1, x2-x1, y2-y1).data;\n","        let r=0, g=0, b=0, n=0;\n","        for (let i=0; i<data.length; i+=4) {\n","          r+=data[i]; g+=data[i+1]; b+=data[i+2]; n++;\n","        }\n","        return [Math.round(r/n), Math.round(g/n), Math.round(b/n)];\n","      }\n","\n","      function drawCrosshair(x, y, color) {\n","        ctx.clearRect(0, 0, canvas.width, canvas.height);\n","        ctx.strokeStyle = color;\n","        ctx.lineWidth = 1.5;\n","        ctx.shadowColor = 'rgba(0,0,0,0.9)';\n","        ctx.shadowBlur = 4;\n","        ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(canvas.width,y); ctx.stroke();\n","        ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,canvas.height); ctx.stroke();\n","        ctx.beginPath(); ctx.arc(x, y, 7, 0, 2*Math.PI);\n","        ctx.lineWidth = 2; ctx.stroke();\n","      }\n","\n","      function updatePreview(hex, r, g, b) {\n","        swatch.style.background = hex;\n","        hexLbl.textContent = hex;\n","        rgbLbl.textContent = `RGB: ${r}, ${g}, ${b}`;\n","      }\n","\n","      canvas.addEventListener('mousemove', function(e) {\n","        if (locked) return;\n","        const rect = canvas.getBoundingClientRect();\n","        const x = Math.round(e.clientX - rect.left);\n","        const y = Math.round(e.clientY - rect.top);\n","        const [r,g,b] = getAvgColor(x, y);\n","        drawCrosshair(x, y, 'white');\n","        updatePreview(toHex(r,g,b), r, g, b);\n","      });\n","\n","      canvas.addEventListener('click', function(e) {\n","        const rect = canvas.getBoundingClientRect();\n","        const x = Math.round(e.clientX - rect.left);\n","        const y = Math.round(e.clientY - rect.top);\n","        const [r,g,b] = getAvgColor(x, y);\n","        const hex = toHex(r,g,b);\n","        locked = true;\n","        drawCrosshair(x, y, '#2196F3');\n","        updatePreview(hex, r, g, b);\n","        swatch.style.border = '3px solid #2196F3';\n","        hexLbl.style.color = '#2196F3';\n","        hexLbl.textContent = hex + ' 🔒';\n","        status.textContent = '🔒 Locked! Double-click to re-pick.';\n","        status.style.color = '#2196F3';\n","        window['picked_left_iris'] = { hex, r, g, b };\n","      });\n","\n","      canvas.addEventListener('dblclick', function(e) {\n","        locked = false;\n","        ctx.clearRect(0, 0, canvas.width, canvas.height);\n","        swatch.style.border = '2px solid #ccc';\n","        hexLbl.style.color = 'black';\n","        hexLbl.textContent = hexLbl.textContent.replace(' 🔒','');\n","        status.textContent = 'Click image to lock a color';\n","        status.style.color = '#888';\n","      });\n","\n","      window['confirmColor_left_iris'] = function() {\n","        const p = window['picked_left_iris'];\n","        if (!p) {\n","          alert('Please click on the image first!');\n","          return;\n","        }\n","        window['result_left_iris'] = JSON.stringify(p);\n","        hexLbl.textContent = '✅ ' + p.hex;\n","        hexLbl.style.color = 'green';\n","        status.textContent = '✅ Color confirmed!';\n","        status.style.color = 'green';\n","        swatch.style.border = '3px solid green';\n","      };\n","    })();\n","    </script>\n","    "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","⏳ Waiting for you to pick and confirm the left_iris color...\n","   Hover → preview | Click → lock 🔒 | Double-click → unlock | ✅ Confirm\n","✓ Received: #6C6660 RGB=[108, 102, 96]\n","✓ left_iris set to #6C6660\n","\n","👀 Do both eyes have the same color? (y/n): y\n","✓ right_iris set to same color: #6C6660\n","\n","======================================================================\n","Region colors for this image:\n","======================================================================\n","  face_skin: RGB=[202, 149, 121], hex=#CA9579\n","  eyebrows: RGB=[149, 108, 85], hex=#956C55\n","  lips: RGB=[180, 115, 102], hex=#B47366\n","  nose: RGB=[221, 170, 145], hex=#DDAA91\n","  left_iris: RGB=[108, 102, 96], hex=#6C6660 (manual)\n","  right_iris: RGB=[108, 102, 96], hex=#6C6660 (manual)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x500 with 9 Axes>"],"image/png":"\n"},"metadata":{}}]}]}
"    cmap = matplotlib.colormaps.get_cmap(\"rainbow\").resampled(n_masks)\n","    colors = [\n","        tuple(int(c * 255) for c in cmap(i)[:3])\n","        for i in range(n_masks)\n","    ]\n","\n","    for mask, color in zip(masks, colors):\n","        mask = Image.fromarray(mask)\n","        overlay = Image.new(\"RGBA\", image.size, color + (0,))\n","        alpha = mask.point(lambda v: int(v * 0.5))\n","        overlay.putalpha(alpha)\n","        image = Image.alpha_composite(image, overlay)\n","    return image\n","\n","# Show overlay for all regions (face skin, brows, lips, nose, both irises)\n","if stacked_masks is not None:\n","    out = overlay_masks(image, stacked_masks)\n","    display(out)\n","else:\n","    print(\"No masks to show.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1onmwr2C-r1en8QBoPckloR20jbzSNqR7"},"id":"F-_lUkLGc0wO","executionInfo":{"status":"ok","timestamp":1773909157930,"user_tz":-60,"elapsed":4396,"user":{"displayName":"Ana María Rull Orti","userId":"07867481728939912277"}},"outputId":"85da42f6-b4b4-4eec-f5f4-5b7f07acfe5c"},"execution_count":13,"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}]},{"cell_type":"markdown","source":["#Full code to segment with SAM 3 meta + Get Region Hex\n","\n","RGB image → BGR → LAB\n","→ extract masked pixels\n","→ filter bottom/top 10% luminance\n","→ K-means (k=3) in LAB space\n","→ pick dominant cluster by pixel count\n","→ mean RGB of that cluster → hex"],"metadata":{"id":"nLWXpsqMp0iG"}},{"cell_type":"code","source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from PIL import Image, ImageOps\n","from IPython.display import display, HTML\n","import time\n","import base64\n","import io\n","import json\n","from transformers import Sam3Processor, Sam3Model\n","import torch\n","import matplotlib\n","import cv2\n","from sklearn.cluster import KMeans\n","from google.colab import files, output\n","\n","# ============================================================================\n","# SETUP SAM3 MODEL\n","# ============================================================================\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","model = Sam3Model.from_pretrained(\"facebook/sam3\").to(device)\n","processor = Sam3Processor.from_pretrained(\"facebook/sam3\")\n","\n","# ============================================================================\n","# LOAD AND PREPARE IMAGE\n","# ============================================================================\n","print(\"=\" * 70)\n","print(\"📸 Please upload an image file\")\n","print(\"=\" * 70)\n","uploaded = files.upload()\n","\n","if len(uploaded) == 0:\n","    raise ValueError(\"No file uploaded!\")\n","\n","image_path = list(uploaded.keys())[0]\n","image = Image.open(image_path).convert(\"RGB\")\n","image = ImageOps.exif_transpose(image)\n","img = image\n","img_np = np.array(img)\n","\n","# ============================================================================\n","# HELPER FUNCTIONS\n","# ============================================================================\n","def rgb_to_hex(rgb):\n","    return f\"#{int(rgb[0]):02X}{int(rgb[1]):02X}{int(rgb[2]):02X}\"\n","\n","def get_region_hex(image, mask_bool, n_clusters=3):\n","    \"\"\"LAB K-means dominant color extraction.\"\"\"\n","    img_np = np.array(image)\n","    img_h, img_w = img_np.shape[:2]\n","\n","    if hasattr(mask_bool, \"shape\"):\n","        mask_h, mask_w = mask_bool.shape[:2]\n","        if mask_h != img_h or mask_w != img_w:\n","            mask_pil = Image.fromarray(mask_bool.astype(np.uint8) * 255)\n","            mask_resized = mask_pil.resize((img_w, img_h), Image.NEAREST)\n","            mask_bool = np.array(mask_resized).astype(bool)\n","\n","    img_bgr = cv2.cvtColor(img_np, cv2.COLOR_RGB2BGR)\n","    img_lab = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2LAB)\n","\n","    pixels_lab = img_lab[mask_bool].astype(float)\n","    pixels_rgb = img_np[mask_bool].astype(float)\n","\n","    if len(pixels_lab) == 0:\n","        return None, None\n","\n","    L = pixels_lab[:, 0]\n","    low, high = np.percentile(L, 10), np.percentile(L, 90)\n","    valid = (L >= low) & (L <= high)\n","    pixels_lab = pixels_lab[valid]\n","    pixels_rgb = pixels_rgb[valid]\n","\n","    if len(pixels_lab) < n_clusters:\n","        median_rgb = np.median(pixels_rgb, axis=0).astype(int)\n","        return median_rgb.tolist(), rgb_to_hex(median_rgb)\n","\n","    k = min(n_clusters, len(pixels_lab))\n","    km = KMeans(n_clusters=k, n_init=10, random_state=42)\n","    km.fit(pixels_lab)\n","    counts = np.bincount(km.labels_)\n","    dominant_idx = counts.argmax()\n","    dominant_rgb = pixels_rgb[km.labels_ == dominant_idx]\n","    mean_rgb = dominant_rgb.mean(axis=0).astype(int)\n","    return mean_rgb.tolist(), rgb_to_hex(mean_rgb)\n","\n","def pil_to_base64(pil_img, max_width=500):\n","    \"\"\"Convert PIL image to base64 string for HTML embedding.\"\"\"\n","    ratio = max_width / pil_img.width\n","    new_size = (max_width, int(pil_img.height * ratio))\n","    resized = pil_img.resize(new_size, Image.LANCZOS)\n","    buffered = io.BytesIO()\n","    resized.save(buffered, format=\"JPEG\", quality=90)\n","    b64 = base64.b64encode(buffered.getvalue()).decode(\"utf-8\")\n","    return b64, resized.size\n","\n","def overlay_masks(image, masks):\n","    image = image.convert(\"RGBA\")\n","    masks_np = 255 * masks.cpu().numpy().astype(np.uint8)\n","    n_masks = masks_np.shape[0]\n","    cmap = matplotlib.colormaps.get_cmap(\"rainbow\").resampled(n_masks)\n","    colors = [tuple(int(c * 255) for c in cmap(i)[:3]) for i in range(n_masks)]\n","    for mask, color in zip(masks_np, colors):\n","        mask_img = Image.fromarray(mask)\n","        overlay = Image.new(\"RGBA\", image.size, color + (0,))\n","        alpha = mask_img.point(lambda v: int(v * 0.5))\n","        overlay.putalpha(alpha)\n","        image = Image.alpha_composite(image, overlay)\n","    return image\n","\n","def create_combined_visualization(original_image, segmentation_image, region_hex):\n","    names = [k for k, v in region_hex.items() if v is not None]\n","    n_cols = 3 + max(len(names), 1)\n","    fig, axes = plt.subplots(1, n_cols, figsize=(2 * n_cols, 5))\n","    if n_cols == 1:\n","        axes = [axes]\n","\n","    axes[0].imshow(original_image)\n","    axes[0].set_title(\"Original Face\", fontsize=10, fontweight=\"bold\")\n","    axes[0].axis(\"off\")\n","    axes[1].imshow(segmentation_image)\n","    axes[1].set_title(\"Segmentation\", fontsize=10, fontweight=\"bold\")\n","    axes[1].axis(\"off\")\n","    axes[2].axis(\"off\")\n","\n","    text_content = \"Region Colors\\n\" + \"=\" * 20 + \"\\n\"\n","    for name in names:\n","        manual_tag = \" (manual)\" if region_hex[name].get(\"manual\") else \"\"\n","        text_content += f\"{name}:\\n  RGB={region_hex[name]['avg_rgb']}\\n  hex={region_hex[name]['hex']}{manual_tag}\\n\\n\"\n","    axes[2].text(0.05, 0.95, text_content, transform=axes[2].transAxes,\n","                 fontsize=8, verticalalignment=\"top\", family=\"monospace\",\n","                 bbox=dict(boxstyle=\"round\", facecolor=\"wheat\", alpha=0.3))\n","\n","    for idx, name in enumerate(names):\n","        ax = axes[3 + idx]\n","        rgb = np.array(region_hex[name][\"avg_rgb\"]) / 255.0\n","        swatch = np.ones((80, 80, 3), dtype=float)\n","        swatch[:] = rgb\n","        ax.imshow(swatch)\n","        ax.axis(\"off\")\n","        manual_tag = \" (manual)\" if region_hex[name].get(\"manual\") else \"\"\n","        ax.set_title(f\"{name}\\n{region_hex[name]['hex']}{manual_tag}\", fontsize=8)\n","\n","    plt.suptitle(\"Face Analysis Results\", fontsize=12, fontweight=\"bold\", y=1.02)\n","    plt.tight_layout()\n","    plt.show()\n","\n","# ============================================================================\n","# HTML COLOR PICKER — eval_js Promise, no kernel blocking\n","# ============================================================================\n","def html_color_picker(img_pil, iris_key, initial_hex=\"#6496C8\"):\n","    b64, (disp_w, disp_h) = pil_to_base64(img_pil, max_width=480)\n","\n","    html_code = f\"\"\"\n","    <div style=\"font-family:monospace; max-width:700px;\">\n","      <h3 style=\"margin-bottom:4px;\">\n","        👁️ {iris_key.replace('_', ' ').title()} — Pick eye color\n","      </h3>\n","      <p style=\"margin:0 0 10px 0; font-size:12px; color:#666;\">\n","        🖱️ Hover to preview &nbsp;|&nbsp;\n","        🖱️ Click to lock color &nbsp;|&nbsp;\n","        🖱️ Double-click to unlock &nbsp;|&nbsp;\n","        ✅ Press Confirm when ready\n","      </p>\n","      <div style=\"display:flex; gap:24px; align-items:flex-start;\">\n","\n","        <div style=\"position:relative; width:{disp_w}px; height:{disp_h}px;\n","                    cursor:crosshair; flex-shrink:0;\">\n","          <img id=\"photo_{iris_key}\"\n","               src=\"data:image/jpeg;base64,{b64}\"\n","               width=\"{disp_w}\" height=\"{disp_h}\"\n","               style=\"display:block; position:absolute; top:0; left:0;\n","                      user-select:none; -webkit-user-drag:none;\"/>\n","          <canvas id=\"canvas_{iris_key}\"\n","                  width=\"{disp_w}\" height=\"{disp_h}\"\n","                  style=\"position:absolute; top:0; left:0;\"></canvas>\n","        </div>\n","\n","        <div style=\"display:flex; flex-direction:column; gap:12px; min-width:170px;\">\n","          <div id=\"swatch_{iris_key}\"\n","               style=\"width:130px; height:130px; border-radius:12px;\n","                      border:2px solid #ccc; background:{initial_hex};\n","                      transition: background 0.1s;\"></div>\n","          <div id=\"hex_label_{iris_key}\"\n","               style=\"font-size:22px; font-weight:bold; letter-spacing:1px;\">\n","            {initial_hex}\n","          </div>\n","          <div id=\"rgb_label_{iris_key}\" style=\"font-size:13px; color:#555;\">\n","            RGB: hover over image\n","          </div>\n","          <div id=\"status_{iris_key}\"\n","               style=\"font-size:12px; color:#888; min-height:18px;\">\n","            Click image to lock a color\n","          </div>\n","          <button onclick=\"confirmColor_{iris_key}()\"\n","                  style=\"margin-top:4px; padding:10px 18px; font-size:14px;\n","                         background:#2196F3; color:white; border:none;\n","                         border-radius:8px; cursor:pointer; font-weight:bold;\">\n","            ✅ Confirm this color\n","          </button>\n","        </div>\n","      </div>\n","    </div>\n","\n","    <script>\n","    (function() {{\n","      const canvas  = document.getElementById('canvas_{iris_key}');\n","      const ctx     = canvas.getContext('2d');\n","      const imgEl   = document.getElementById('photo_{iris_key}');\n","      const swatch  = document.getElementById('swatch_{iris_key}');\n","      const hexLbl  = document.getElementById('hex_label_{iris_key}');\n","      const rgbLbl  = document.getElementById('rgb_label_{iris_key}');\n","      const status  = document.getElementById('status_{iris_key}');\n","\n","      const off = document.createElement('canvas');\n","      off.width = {disp_w}; off.height = {disp_h};\n","      const offCtx = off.getContext('2d');\n","      const drawOff = () => offCtx.drawImage(imgEl, 0, 0);\n","      if (imgEl.complete) drawOff(); else imgEl.onload = drawOff;\n","\n","      let locked = false;\n","\n","      function toHex(r, g, b) {{\n","        return '#' + [r,g,b].map(v =>\n","          v.toString(16).padStart(2,'0').toUpperCase()).join('');\n","      }}\n","\n","      function getAvgColor(x, y, radius=8) {{\n","        const x1 = Math.max(0, x-radius), y1 = Math.max(0, y-radius);\n","        const x2 = Math.min({disp_w}, x+radius), y2 = Math.min({disp_h}, y+radius);\n","        const data = offCtx.getImageData(x1, y1, x2-x1, y2-y1).data;\n","        let r=0, g=0, b=0, n=0;\n","        for (let i=0; i<data.length; i+=4) {{\n","          r+=data[i]; g+=data[i+1]; b+=data[i+2]; n++;\n","        }}\n","        return [Math.round(r/n), Math.round(g/n), Math.round(b/n)];\n","      }}\n","\n","      function drawCrosshair(x, y, color) {{\n","        ctx.clearRect(0, 0, canvas.width, canvas.height);\n","        ctx.strokeStyle = color;\n","        ctx.lineWidth = 1.5;\n","        ctx.shadowColor = 'rgba(0,0,0,0.9)';\n","        ctx.shadowBlur = 4;\n","        ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(canvas.width,y); ctx.stroke();\n","        ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,canvas.height); ctx.stroke();\n","        ctx.beginPath(); ctx.arc(x, y, 7, 0, 2*Math.PI);\n","        ctx.lineWidth = 2; ctx.stroke();\n","      }}\n","\n","      function updatePreview(hex, r, g, b) {{\n","        swatch.style.background = hex;\n","        hexLbl.textContent = hex;\n","        rgbLbl.textContent = `RGB: ${{r}}, ${{g}}, ${{b}}`;\n","      }}\n","\n","      canvas.addEventListener('mousemove', function(e) {{\n","        if (locked) return;\n","        const rect = canvas.getBoundingClientRect();\n","        const x = Math.round(e.clientX - rect.left);\n","        const y = Math.round(e.clientY - rect.top);\n","        const [r,g,b] = getAvgColor(x, y);\n","        drawCrosshair(x, y, 'white');\n","        updatePreview(toHex(r,g,b), r, g, b);\n","      }});\n","\n","      canvas.addEventListener('click', function(e) {{\n","        const rect = canvas.getBoundingClientRect();\n","        const x = Math.round(e.clientX - rect.left);\n","        const y = Math.round(e.clientY - rect.top);\n","        const [r,g,b] = getAvgColor(x, y);\n","        const hex = toHex(r,g,b);\n","        locked = true;\n","        drawCrosshair(x, y, '#2196F3');\n","        updatePreview(hex, r, g, b);\n","        swatch.style.border = '3px solid #2196F3';\n","        hexLbl.style.color = '#2196F3';\n","        hexLbl.textContent = hex + ' 🔒';\n","        status.textContent = '🔒 Locked! Double-click to re-pick.';\n","        status.style.color = '#2196F3';\n","        window['picked_{iris_key}'] = {{ hex, r, g, b }};\n","      }});\n","\n","      canvas.addEventListener('dblclick', function(e) {{\n","        locked = false;\n","        ctx.clearRect(0, 0, canvas.width, canvas.height);\n","        swatch.style.border = '2px solid #ccc';\n","        hexLbl.style.color = 'black';\n","        hexLbl.textContent = hexLbl.textContent.replace(' 🔒','');\n","        status.textContent = 'Click image to lock a color';\n","        status.style.color = '#888';\n","      }});\n","\n","      window['confirmColor_{iris_key}'] = function() {{\n","        const p = window['picked_{iris_key}'];\n","        if (!p) {{\n","          alert('Please click on the image first!');\n","          return;\n","        }}\n","        window['result_{iris_key}'] = JSON.stringify(p);\n","        hexLbl.textContent = '✅ ' + p.hex;\n","        hexLbl.style.color = 'green';\n","        status.textContent = '✅ Color confirmed!';\n","        status.style.color = 'green';\n","        swatch.style.border = '3px solid green';\n","      }};\n","    }})();\n","    </script>\n","    \"\"\"\n","\n","    display(HTML(html_code))\n","\n","    print(f\"\\n⏳ Waiting for you to pick and confirm the {iris_key} color...\")\n","    print(\"   Hover → preview | Click → lock 🔒 | Double-click → unlock | ✅ Confirm\")\n","\n","    result_json = output.eval_js(f\"\"\"\n","      new Promise((resolve) => {{\n","        const interval = setInterval(() => {{\n","          if (window['result_{iris_key}']) {{\n","            clearInterval(interval);\n","            resolve(window['result_{iris_key}']);\n","          }}\n","        }}, 500);\n","      }})\n","    \"\"\")\n","\n","    result = json.loads(result_json)\n","    rgb = [result[\"r\"], result[\"g\"], result[\"b\"]]\n","    hex_color = result[\"hex\"]\n","    print(f\"✓ Received: {hex_color} RGB={rgb}\")\n","    return rgb, hex_color\n","\n","# ============================================================================\n","# SAM3 PROMPTS — no iris, handled by picker\n","# ============================================================================\n","prompts = [\n","    \"skin of the face\",\n","    \"eyebrows\",\n","    \"lips\",\n","    \"nose\",\n","]\n","\n","prompt_keys = {\n","    \"skin of the face\": \"face_skin\",\n","    \"eyebrows\": \"eyebrows\",\n","    \"lips\": \"lips\",\n","    \"nose\": \"nose\",\n","}\n","\n","all_inputs, all_outputs = [], []\n","for text in prompts:\n","    inputs = processor(images=image, text=text, return_tensors=\"pt\").to(device)\n","    with torch.no_grad():\n","        outputs = model(**inputs)\n","    all_inputs.append(inputs)\n","    all_outputs.append(outputs)\n","\n","# ============================================================================\n","# POST-PROCESS MASKS\n","# ============================================================================\n","selected_masks = []\n","for text, inputs, outputs in zip(prompts, all_inputs, all_outputs):\n","    results = processor.post_process_instance_segmentation(\n","        outputs, threshold=0.5, mask_threshold=0.5,\n","        target_sizes=inputs.get(\"original_sizes\").tolist(),\n","    )[0]\n","    print(f\"Prompt '{text}': found {len(results['masks'])} objects\")\n","    if len(results[\"masks\"]) > 0:\n","        masks = results[\"masks\"]\n","        areas = masks.view(masks.shape[0], -1).sum(dim=1)\n","        selected_masks.append(masks[int(areas.argmax())])\n","    else:\n","        selected_masks.append(None)\n","\n","region_masks = {}\n","for text, mask in zip(prompts, selected_masks):\n","    key = prompt_keys[text]\n","    region_masks[key] = mask.bool() if mask is not None else None\n","\n","# ============================================================================\n","# SEGMENTATION OVERLAY\n","# ============================================================================\n","valid_masks = [m for m in selected_masks if m is not None]\n","segmentation_image = overlay_masks(image, torch.stack(valid_masks)) if valid_masks else image\n","\n","# ============================================================================\n","# EXTRACT HEX COLORS WITH LAB K-MEANS (non-iris regions only)\n","# ============================================================================\n","region_hex = {}\n","for name, mask in region_masks.items():\n","    if mask is None:\n","        region_hex[name] = None\n","        continue\n","    mask_bool = mask.cpu().numpy().astype(bool) if hasattr(mask, \"cpu\") else mask.astype(bool)\n","    avg_rgb, hex_col = get_region_hex(img, mask_bool, n_clusters=3)\n","    region_hex[name] = {\"avg_rgb\": avg_rgb, \"hex\": hex_col, \"manual\": False} if avg_rgb is not None else None\n","\n","# ============================================================================\n","# EYE COLOR — always use HTML picker, ask if both eyes same color\n","# ============================================================================\n","print(f\"\\n{'='*70}\")\n","print(f\"👁️  Left Iris — click on the eye in the photo\")\n","print(f\"{'='*70}\")\n","picked_rgb_left, picked_hex_left = html_color_picker(img, \"left_iris\", initial_hex=\"#6496C8\")\n","region_hex[\"left_iris\"] = {\"avg_rgb\": picked_rgb_left, \"hex\": picked_hex_left, \"manual\": True}\n","print(f\"✓ left_iris set to {picked_hex_left}\")\n","\n","same_color = input(\"\\n👀 Do both eyes have the same color? (y/n): \").strip().lower()\n","\n","if same_color == \"y\":\n","    region_hex[\"right_iris\"] = {\"avg_rgb\": picked_rgb_left, \"hex\": picked_hex_left, \"manual\": True}\n","    print(f\"✓ right_iris set to same color: {picked_hex_left}\")\n","else:\n","    print(f\"\\n{'='*70}\")\n","    print(f\"👁️  Right Iris — click on the eye in the photo\")\n","    print(f\"{'='*70}\")\n","    picked_rgb_right, picked_hex_right = html_color_picker(img, \"right_iris\", initial_hex=\"#6496C8\")\n","    region_hex[\"right_iris\"] = {\"avg_rgb\": picked_rgb_right, \"hex\": picked_hex_right, \"manual\": True}\n","    print(f\"✓ right_iris set to {picked_hex_right}\")\n","\n","# ============================================================================\n","# FINAL OUTPUT\n","# ============================================================================\n","print(\"\\n\" + \"=\" * 70)\n","print(\"Region colors for this image:\")\n","print(\"=\" * 70)\n","for name, info in region_hex.items():\n","    if info is None:\n","        print(f\"  {name}: no pixels\")\n","    else:\n","        manual_tag = \" (manual)\" if info.get(\"manual\") else \"\"\n","        print(f\"  {name}: RGB={info['avg_rgb']}, hex={info['hex']}{manual_tag}\")\n","\n","create_combined_visualization(img, segmentation_image, region_hex)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"referenced_widgets":["100df60438c14553bcea31b075de257d","d0dd07b9ea6f41cea9839602202090da","0a7567bc5cc441c893fb910b87f5e08f","7d7662bdeaf84471b1411283aa4b13cb","d325ea7ab7cb451b899732aa1c7afa5e","ed9548d332a14536a103d996ce4bbb97","3386eac6267d48578dc467cca67818e2","20be6a94f9254701a8dc6de3e0ba3ee0","39e4104b68224e47b5a2c8f3c4a3cea7","a40ed700d8094e37a17f4364aee10727","1110f3fab1af4784886ae3cce0a1e3df"]},"id":"hxGqw8WmpzmF","executionInfo":{"status":"ok","timestamp":1773909460185,"user_tz":-60,"elapsed":55204,"user":{"displayName":"Ana María Rull Orti","userId":"07867481728939912277"}},"outputId":"5398af64-5f9b-4f53-8f53-c9e96ead08bd"},"execution_count":15,"outputs":[{"output_type":"display_data","data":{"text/plain":["Loading weights:   0%|          | 0/1468 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"100df60438c14553bcea31b075de25